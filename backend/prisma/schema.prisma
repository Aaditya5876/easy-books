generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  STAFF
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum TransactionType {
  CASH
  BANK
  QR
  CHEQUE
}

enum TransactionCategory {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum LedgerAccountType {
  PURCHASE
  SALES
  EXPENSE
  ASSET
  LIABILITY
  EQUITY
}

enum InventoryUnit {
  PIECE
  SET
  LITER
  ML
  KG
  GM
  NOS
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum QuotationRemark {
  QUOTED
  WORK_DONE
  CANCELLED
  REVISED
  BILLED
}

enum QuotationStatus {
  ACTIVE
  CONVERTED
  EXPIRED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  role         UserRole  @default(STAFF)
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id])
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

model Company {
  id              String    @id @default(uuid())
  name            String
  address         String?
  phone           String?
  email           String?
  panVat          String?
  logoUrl         String?
  currency        String    @default("NPR")
  fiscalYearStart String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users          User[]
  employees      Employee[]
  attendance     Attendance[]
  payrolls       Payroll[]
  bankAccounts   BankAccount[]
  transactions   Transaction[]
  ledgerAccounts LedgerAccount[]
  ledgerEntries  LedgerEntry[]
  inventoryItems InventoryItem[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  clients        Client[]
  vendors        Vendor[]
  quotations     Quotation[]
  memoDocs       MemoDocument[]
  tasks          Task[]

  @@map("companies")
}

model Employee {
  id            String         @id @default(uuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  name          String
  employeeId    String
  department    String?
  designation   String?
  phone         String?
  email         String?
  address       String?
  dateOfJoining DateTime?
  salary        Decimal        @default(0) @db.Decimal(12, 2)
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  attendance Attendance[]
  payrolls   Payroll[]

  @@map("employees")
}

model Attendance {
  id           String           @id @default(uuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  employeeId   String
  employee     Employee         @relation(fields: [employeeId], references: [id])
  date         DateTime
  status       AttendanceStatus
  checkInTime  String?
  checkOutTime String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("attendance")
}

model Payroll {
  id         String        @id @default(uuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  month      String
  salary     Decimal       @db.Decimal(12, 2)
  deductions Decimal       @default(0) @db.Decimal(12, 2)
  netAmount  Decimal       @db.Decimal(12, 2)
  status     PayrollStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([employeeId, month])
  @@map("payrolls")
}

model BankAccount {
  id             String   @id @default(uuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  bankName       String
  accountNumber  String
  accountType    String?
  branch         String?
  currentBalance Decimal  @default(0) @db.Decimal(14, 2)
  portalUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("bank_accounts")
}

model Transaction {
  id          String              @id @default(uuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])
  dateAd      DateTime
  dateBs      String?
  type        TransactionType
  category    TransactionCategory
  amount      Decimal             @db.Decimal(14, 2)
  description String?
  reference   String?
  status      TransactionStatus   @default(COMPLETED)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("transactions")
}

model LedgerAccount {
  id             String            @id @default(uuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id])
  accountName    String
  accountType    LedgerAccountType
  openingBalance Decimal           @default(0) @db.Decimal(14, 2)
  currentBalance Decimal           @default(0) @db.Decimal(14, 2)
  fiscalYear     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  entries LedgerEntry[]

  @@map("ledger_accounts")
}

model LedgerEntry {
  id            String        @id @default(uuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  accountId     String
  account       LedgerAccount @relation(fields: [accountId], references: [id])
  dateAd        DateTime
  dateBs        String?
  description   String?
  debit         Decimal       @default(0) @db.Decimal(14, 2)
  credit        Decimal       @default(0) @db.Decimal(14, 2)
  balance       Decimal       @default(0) @db.Decimal(14, 2)
  referenceType String?
  referenceId   String?
  isLocked      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("ledger_entries")
}

model InventoryItem {
  id                String        @id @default(uuid())
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  brand             String?
  modelNo           String?
  description       String?
  application       String?
  imageUrl          String?
  quantity          Decimal       @default(0) @db.Decimal(12, 3)
  unit              InventoryUnit @default(PIECE)
  unitPurchasePrice Decimal       @default(0) @db.Decimal(12, 2)
  unitSellingPrice  Decimal       @default(0) @db.Decimal(12, 2)
  stockLocation     String?
  lowStockThreshold Decimal       @default(0) @db.Decimal(12, 3)
  agingDays         Int?
  supplierName      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@map("inventory_items")
}

model Client {
  id            String       @id @default(uuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  crmStatus     ClientStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  salesOrders SalesOrder[]
  quotations  Quotation[]

  @@map("clients")
}

model Vendor {
  id            String    @id @default(uuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  bankDetails   String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model SalesOrder {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id])
  clientName    String
  clientContact String?
  clientAddress String?
  dateAd        DateTime
  dateBs        String?
  invoiceNumber String
  items         Json
  laborCharges  Decimal     @default(0) @db.Decimal(12, 2)
  isVat         Boolean     @default(false)
  subtotal      Decimal     @db.Decimal(14, 2)
  vatAmount     Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(14, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([companyId, invoiceNumber])
  @@map("sales_orders")
}

model PurchaseOrder {
  id            String      @id @default(uuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  vendorId      String?
  vendor        Vendor?     @relation(fields: [vendorId], references: [id])
  vendorName    String
  vendorContact String?
  vendorAddress String?
  dateAd        DateTime
  dateBs        String?
  orderNumber   String
  items         Json
  laborCharges  Decimal     @default(0) @db.Decimal(12, 2)
  isVat         Boolean     @default(false)
  subtotal      Decimal     @db.Decimal(14, 2)
  vatAmount     Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(14, 2)
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([companyId, orderNumber])
  @@map("purchase_orders")
}

model Quotation {
  id              String          @id @default(uuid())
  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  clientName      String
  dateAd          DateTime
  dateBs          String?
  quotationNumber String
  items           Json
  description     String?
  totalAmount     Decimal         @db.Decimal(14, 2)
  remark          QuotationRemark @default(QUOTED)
  status          QuotationStatus @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([companyId, quotationNumber])
  @@map("quotations")
}

model MemoDocument {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  title        String
  content      String?
  dateAd       DateTime
  dateBs       String?
  documentType String?
  attachments  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("memo_documents")
}

model Task {
  id          String       @id @default(uuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  title       String
  description String?
  assignedTo  String?
  dueDate     DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("tasks")
}
